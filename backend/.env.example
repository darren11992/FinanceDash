# =============================================================================
# Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Found in: Supabase Dashboard → Settings → API Keys
# See: https://github.com/orgs/supabase/discussions/29260
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-supabase-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-supabase-secret-key
# JWT verification uses the JWKS endpoint (asymmetric signing key).
# No shared secret needed — public key is auto-fetched from:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# See: https://supabase.com/docs/guides/auth/signing-keys

# -----------------------------------------------------------------------------
# TrueLayer
# -----------------------------------------------------------------------------
# Found in: TrueLayer Console → Settings
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
TRUELAYER_REDIRECT_URI=pennyapp://callback

# Set to "sandbox" for development, "live" for production
TRUELAYER_ENV=sandbox

# Sandbox URLs (change to production URLs when TRUELAYER_ENV=live)
TRUELAYER_AUTH_BASE_URL=https://auth.truelayer-sandbox.com
TRUELAYER_DATA_BASE_URL=https://api.truelayer-sandbox.com

# -----------------------------------------------------------------------------
# Token Encryption
# -----------------------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TRUELAYER_TOKEN_ENCRYPTION_KEY=your-fernet-encryption-key

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
